# Synthetic findlib package(s) exposing the BER MetaOCaml 5.3.0 runtime.
#
# BER installs its runtime into the compiler's own stdlib dir without a findlib
# package. `directory = "+"` is findlib's token for that dir, so nothing here
# hardcodes a (Nix) store path.
description = "BER MetaOCaml runtime, native (Runnative)"
version = "5.3.0+BER"
directory = "+"
requires = "compiler-libs.optcomp dynlink"
archive(native) = "codelib.cmx runnative.cmx"

package "byte" (
  description = "BER MetaOCaml runtime, bytecode (Runcode)"
  version = "5.3.0+BER"
  requires = "compiler-libs.toplevel dynlink"
  archive(byte) = "metalib.cma"
)
